# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored — never commit real secrets.

# Generate with:  mix phx.gen.secret
SECRET_KEY_BASE=

# Public hostname the app is served from (used for URLs / force_ssl exclusion).
PHX_HOST=localhost

# Database credentials for the TimescaleDB container.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dtu_app_prod

# DB connection pool size.
POOL_SIZE=15

# Embedded MQTT broker.
MQTT_BROKER_ENABLED=true

# Transactional email via the Resend API (https://resend.com).
# Leave RESEND_API_KEY empty to fall back to the in-memory mailer (emails are
# swallowed — magic-link login will not work without a real key).
RESEND_API_KEY=
# Sender address — must be on a domain you have verified in Resend.
# Use the "Name <address@domain>" form, e.g. "DtuApp <noreply@mail.example.com>".
MAIL_FROM=DtuApp <noreply@localhost>
